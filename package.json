{
  "name": "@oddmaki-protocol/sdk",
  "version": "0.1.0",
  "description": "OddMaki Protocol SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "sync-core": "node scripts/sync-core.js",
    "prepublishOnly": "pnpm run lint && pnpm run test && pnpm run build"
  },
  "keywords": [
    "oddmaki",
    "protocol",
    "sdk",
    "web3",
    "prediction-market"
  ],
  "author": "Predictable Reality, Inc.",
  "contributors": [
    "Carlos Revelo (https://github.com/crevelop)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddmaki/oddmaki-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
