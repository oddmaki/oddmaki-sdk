{
  "name": "@oddmaki/sdk",
  "version": "0.0.1",
  "description": "OddMaki Protocol SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "oddmaki",
    "protocol",
    "sdk",
    "web3",
    "prediction-market"
  ],
  "author": "OddMaki",
  "license": "Apache-2.0",
  "dependencies": {
    "viem": "^2.21.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.24",
    "vitest": "^1.3.1"
  }
}
